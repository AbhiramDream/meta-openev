# ──────────────────────────────────────────────────────────────────────────────
# Supply Chain OpenEnv — environment variables
#
# Copy this file to .env and fill in your real values.
# NEVER commit the populated .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Mandatory ─────────────────────────────────────────────────────────────────

# Base URL of the LLM API endpoint.
# Examples:
#   https://api.openai.com/v1              (OpenAI)
#   https://api-inference.huggingface.co/v1 (HF Inference API)
#   http://localhost:11434/v1              (Ollama local)
API_BASE_URL=https://api.openai.com/v1

# Model identifier understood by the endpoint above.
# Examples: gpt-4o-mini, gpt-4o, meta-llama/Llama-3-8b-instruct
MODEL_NAME=gpt-4o-mini

# Your Hugging Face token or OpenAI-compatible API key.
# This is sent as the Bearer token in every LLM API call.
HF_TOKEN=hf_YOUR_TOKEN_HERE

# ── Optional ──────────────────────────────────────────────────────────────────

# Base URL of the running OpenEnv server.
# When running inference against the deployed HF Space, set this to:
#   https://<your-space-name>.hf.space
ENV_BASE_URL=http://localhost:7860

# Comma-separated list of tasks to evaluate.
TASKS=easy,medium,hard

# Random seed for reproducible runs.
SEED=42
